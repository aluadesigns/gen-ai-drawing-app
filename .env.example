# Copy this file to .env.local and fill in real values.
# NEVER prefix these variables with NEXT_PUBLIC_ — that would bundle them into client JS.

# FAL.ai — get a key at https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key-here

# Supabase — from https://supabase.com/dashboard/project/<project>/settings/api
# SUPABASE_URL is the project URL (e.g. https://xxxxx.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY is the `service_role` secret — bypasses RLS, server-only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
